<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg">

    <LinearLayout
        android:id="@+id/header"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_marginTop="20dp"
        android:layout_marginBottom="10dp"
        android:gravity="center"
        android:layout_alignParentTop="true">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="sans-serif-black"
            android:text="Écriture Données Médicales"
            android:textColor="#FFFFFF"
            android:textSize="22sp"
            android:textStyle="bold"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="sans-serif"
            android:text="Remplissez les champs et approchez un tag NFC"
            android:textColor="#FFFFFF"
            android:textSize="14sp"/>
    </LinearLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_below="@id/header"
        android:layout_above="@id/footer"
        android:paddingLeft="16dp"
        android:paddingRight="16dp"
        android:scrollbars="none">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Nom -->
            <RelativeLayout android:layout_width="match_parent" android:layout_height="wrap_content">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Nom (25 char)" android:textColor="#FFFFFF" android:textSize="12sp" android:layout_alignParentLeft="true" />
                <TextView android:id="@+id/tvCountNom" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="25" android:textColor="#FFFFFF" android:textSize="12sp" android:layout_alignParentRight="true" />
            </RelativeLayout>
            <EditText android:id="@+id/etNom" android:layout_width="match_parent" android:layout_height="wrap_content" android:hint="Nom" android:maxLength="25" android:background="@drawable/button" android:padding="12dp" android:layout_marginBottom="8dp" android:inputType="textCapCharacters" android:textColorHint="#8E8E8E" />

            <!-- Prénom -->
            <RelativeLayout android:layout_width="match_parent" android:layout_height="wrap_content">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Prénom (25 char)" android:textColor="#FFFFFF" android:textSize="12sp" android:layout_alignParentLeft="true" />
                <TextView android:id="@+id/tvCountPrenom" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="25" android:textColor="#FFFFFF" android:textSize="12sp" android:layout_alignParentRight="true" />
            </RelativeLayout>
            <EditText android:id="@+id/etPrenom" android:layout_width="match_parent" android:layout_height="wrap_content" android:hint="Prénom" android:maxLength="25" android:background="@drawable/button" android:padding="12dp" android:layout_marginBottom="8dp" android:textColorHint="#8E8E8E" />

            <!-- Date Naissance -->
            <RelativeLayout android:layout_width="match_parent" android:layout_height="wrap_content">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Date Naissance (JJ/MM/AAAA)" android:textColor="#FFFFFF" android:textSize="12sp" android:layout_alignParentLeft="true" />
                <TextView android:id="@+id/tvCountDate" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="10" android:textColor="#FFFFFF" android:textSize="12sp" android:layout_alignParentRight="true" />
            </RelativeLayout>
            <EditText android:id="@+id/etDateNaissance" android:layout_width="match_parent" android:layout_height="wrap_content" android:hint="Date Naissance" android:maxLength="10" android:background="@drawable/button" android:padding="12dp" android:layout_marginBottom="8dp" android:inputType="date" android:textColorHint="#8E8E8E" />

            <!-- Sexe -->
            <RelativeLayout android:layout_width="match_parent" android:layout_height="wrap_content">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Sexe (M/F/..)" android:textColor="#FFFFFF" android:textSize="12sp" android:layout_alignParentLeft="true" />
                <TextView android:id="@+id/tvCountSexe" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="10" android:textColor="#FFFFFF" android:textSize="12sp" android:layout_alignParentRight="true" />
            </RelativeLayout>
            <EditText android:id="@+id/etSexe" android:layout_width="match_parent" android:layout_height="wrap_content" android:hint="Sexe" android:maxLength="10" android:background="@drawable/button" android:padding="12dp" android:layout_marginBottom="8dp" android:textColorHint="#8E8E8E" />

            <!-- Adresse -->
            <RelativeLayout android:layout_width="match_parent" android:layout_height="wrap_content">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Adresse (50 char)" android:textColor="#FFFFFF" android:textSize="12sp" android:layout_alignParentLeft="true" />
                <TextView android:id="@+id/tvCountAdresse" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="50" android:textColor="#FFFFFF" android:textSize="12sp" android:layout_alignParentRight="true" />
            </RelativeLayout>
            <EditText android:id="@+id/etAdresse" android:layout_width="match_parent" android:layout_height="wrap_content" android:hint="Adresse" android:maxLength="50" android:background="@drawable/button" android:padding="12dp" android:layout_marginBottom="8dp" android:textColorHint="#8E8E8E" />

            <!-- Contact Urgence -->
            <RelativeLayout android:layout_width="match_parent" android:layout_height="wrap_content">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Contact Urgence (39 char)" android:textColor="#FFFFFF" android:textSize="12sp" android:layout_alignParentLeft="true" />
                <TextView android:id="@+id/tvCountContact" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="39" android:textColor="#FFFFFF" android:textSize="12sp" android:layout_alignParentRight="true" />
            </RelativeLayout>
            <EditText android:id="@+id/etContactUrgence" android:layout_width="match_parent" android:layout_height="wrap_content" android:hint="Contact Urgence" android:maxLength="39" android:background="@drawable/button" android:padding="12dp" android:layout_marginBottom="8dp" android:textColorHint="#8E8E8E" />

            <!-- Taille / Poids / Typage sanguin -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="12dp">
                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical" android:layout_marginEnd="8dp">
                    <RelativeLayout android:layout_width="match_parent" android:layout_height="wrap_content">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Taille" android:textColor="#FFFFFF" android:textSize="10sp" />
                        <TextView android:id="@+id/tvCountTaille" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="3" android:textColor="#FFFFFF" android:textSize="10sp" android:layout_alignParentRight="true" />
                    </RelativeLayout>
                    <EditText android:id="@+id/etTaille" android:layout_width="match_parent" android:layout_height="wrap_content" android:hint="cm" android:maxLength="3" android:background="@drawable/button" android:padding="12dp" android:inputType="number" android:textColorHint="#8E8E8E" />
                </LinearLayout>
                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical" android:layout_marginEnd="8dp">
                    <RelativeLayout android:layout_width="match_parent" android:layout_height="wrap_content">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Poids" android:textColor="#FFFFFF" android:textSize="10sp" />
                        <TextView android:id="@+id/tvCountPoids" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="5" android:textColor="#FFFFFF" android:textSize="10sp" android:layout_alignParentRight="true" />
                    </RelativeLayout>
                    <EditText android:id="@+id/etPoids" android:layout_width="match_parent" android:layout_height="wrap_content" android:hint="kg" android:maxLength="5" android:background="@drawable/button" android:padding="12dp" android:inputType="numberDecimal" android:textColorHint="#8E8E8E" />
                </LinearLayout>
                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1.2" android:orientation="vertical">
                    <RelativeLayout android:layout_width="match_parent" android:layout_height="wrap_content">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Typage sanguin" android:textColor="#FFFFFF" android:textSize="10sp" />
                        <TextView android:id="@+id/tvCountSang" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="3" android:textColor="#FFFFFF" android:textSize="10sp" android:layout_alignParentRight="true" />
                    </RelativeLayout>
                    <EditText android:id="@+id/etGroupeSanguin" android:layout_width="match_parent" android:layout_height="wrap_content" android:hint="Sang" android:maxLength="3" android:background="@drawable/button" android:padding="12dp" android:textColorHint="#8E8E8E" />
                </LinearLayout>
            </LinearLayout>

            <!-- Allergies -->
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Allergies (Max 2)" android:textColor="#FFFFFF" android:layout_marginBottom="4dp" android:textSize="12sp" android:textStyle="bold" />
            <RelativeLayout android:layout_width="match_parent" android:layout_height="wrap_content">
                <TextView android:id="@+id/tvCountAllergie1" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="30" android:textColor="#FFFFFF" android:textSize="10sp" android:layout_alignParentRight="true" />
            </RelativeLayout>
            <EditText android:id="@+id/etAllergie1" android:layout_width="match_parent" android:layout_height="wrap_content" android:hint="Allergie 1" android:maxLength="30" android:background="@drawable/button" android:padding="12dp" android:layout_marginBottom="4dp" android:textColorHint="#8E8E8E" />
            <RelativeLayout android:layout_width="match_parent" android:layout_height="wrap_content">
                <TextView android:id="@+id/tvCountAllergie2" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="30" android:textColor="#FFFFFF" android:textSize="10sp" android:layout_alignParentRight="true" />
            </RelativeLayout>
            <EditText android:id="@+id/etAllergie2" android:layout_width="match_parent" android:layout_height="wrap_content" android:hint="Allergie 2" android:maxLength="30" android:background="@drawable/button" android:padding="12dp" android:layout_marginBottom="12dp" android:textColorHint="#8E8E8E" />

            <!-- Maladies Chroniques -->
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Maladies Chroniques" android:textColor="#FFFFFF" android:layout_marginBottom="4dp" android:textSize="12sp" android:textStyle="bold" />
            <RelativeLayout android:layout_width="match_parent" android:layout_height="wrap_content">
                <TextView android:id="@+id/tvCountMaladie1" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="50" android:textColor="#FFFFFF" android:textSize="10sp" android:layout_alignParentRight="true" />
            </RelativeLayout>
            <EditText android:id="@+id/etMaladie1" android:layout_width="match_parent" android:layout_height="wrap_content" android:hint="Maladie" android:maxLength="50" android:background="@drawable/button" android:padding="12dp" android:layout_marginBottom="12dp" android:textColorHint="#8E8E8E" />

            <!-- Traitement -->
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Traitement" android:textColor="#FFFFFF" android:layout_marginBottom="4dp" android:textSize="12sp" android:textStyle="bold" />
            <RelativeLayout android:layout_width="match_parent" android:layout_height="wrap_content">
                <TextView android:id="@+id/tvCountTraitement1" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="30" android:textColor="#FFFFFF" android:textSize="10sp" android:layout_alignParentRight="true" />
            </RelativeLayout>
            <EditText android:id="@+id/etTraitement1" android:layout_width="match_parent" android:layout_height="wrap_content" android:hint="Traitement" android:maxLength="30" android:background="@drawable/button" android:padding="12dp" android:layout_marginBottom="12dp" android:textColorHint="#8E8E8E" />

            <!-- Dispositif médical -->
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Dispositif médical" android:textColor="#FFFFFF" android:layout_marginBottom="4dp" android:textSize="12sp" android:textStyle="bold" />
            <RelativeLayout android:layout_width="match_parent" android:layout_height="wrap_content">
                <TextView android:id="@+id/tvCountDispositif1" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="50" android:textColor="#FFFFFF" android:textSize="10sp" android:layout_alignParentRight="true" />
            </RelativeLayout>
            <EditText android:id="@+id/etDispositif1" android:layout_width="match_parent" android:layout_height="wrap_content" android:hint="Dispositif médical" android:maxLength="50" android:background="@drawable/button" android:padding="12dp" android:layout_marginBottom="16dp" android:textColorHint="#8E8E8E" />

        </LinearLayout>
    </ScrollView>

    <LinearLayout
        android:id="@+id/footer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_alignParentBottom="true"
        android:padding="16dp">

        <Button
            android:id="@+id/btnback"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/button"
            android:text="RETOUR"
            android:textColor="#0099ff"
            android:textStyle="bold"
            android:textAllCaps="true"/>
    </LinearLayout>

</RelativeLayout>
